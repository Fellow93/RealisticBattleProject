		<!-- Agent Posture Info -->
		<TextWidget Brush="RBMLabels" HorizontalAlignment="Right" VerticalAlignment="Bottom" SuggestedWidth="100" MarginBottom="37" MarginRight="235" Text="Posture" IsVisible="@ShowPlayerPostureBar" />
		<Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="220" SuggestedHeight="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="27" MarginRight="35" Sprite="HintBG@2x_9" IsVisible="@ShowPlayerPostureBar" />
		<FillBar WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="210" SuggestedHeight="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="28" MarginRight="40" Brush="PlayerPostureBarBrush" InitialAmount="@PlayerPosture" MaxAmount="@PlayerPostureMax" IsVertical="false" IsVisible="@ShowPlayerPostureBar" />
		<TextWidget Brush="RBMLabels" SuggestedWidth="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="37" MarginRight="120" IsVisible="@ShowPlayerPostureBar" Text="@PlayerPostureText" />
		<TextWidget Brush="RBMLabels" SuggestedWidth="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="37" MarginRight="100" IsVisible="@ShowPlayerPostureBar" Text="/" />
		<TextWidget Brush="RBMLabels" SuggestedWidth="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="37" MarginRight="80" IsVisible="@ShowPlayerPostureBar" Text="@PlayerPostureMaxText" />

